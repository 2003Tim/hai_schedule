<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_today_bg_light"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top|center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/header_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="3月8日"
                android:textColor="#15253D"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/header_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:maxLines="1"
                android:text="星期六 · 今天 · 第2周 · 2节"
                android:textColor="#5E718B"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_nav_btn_bg_light"
            android:gravity="center"
            android:text="‹"
            android:textColor="#24415F"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_today"
            android:layout_width="38dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_nav_btn_active_bg_light"
            android:gravity="center"
            android:text="今"
            android:textColor="#2158C7"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_nav_btn_bg_light"
            android:gravity="center"
            android:text="›"
            android:textColor="#24415F"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/top_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#D7E0EA" />

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/course_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/course_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/widget_today_card_bg_light"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="13dp">

                <LinearLayout
                    android:id="@+id/course_indicator_1"
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="#C9D9F6FF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/course_title_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="机器学习"
                        android:textColor="#15253D"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/course_meta_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="16:35-18:15 · 第7-8节 · 1-T303 · 刘老师"
                        android:textColor="#6A7C96"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/course_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:maxLines="1"
                    android:text="30分钟后上课"
                    android:textColor="#2158C7"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/course_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_today_card_bg_light"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="13dp">

                <LinearLayout
                    android:id="@+id/course_indicator_2"
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="#D6CFF7FF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/course_title_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="数据挖掘"
                        android:textColor="#15253D"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/course_meta_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="14:30-16:10 · 第5-6节 · 2-306 · 孔老师"
                        android:textColor="#6A7C96"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/course_status_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:maxLines="1"
                    android:text="距下课 18 分钟"
                    android:textColor="#006D77"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/more_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="还有 1 节课程未显示"
                android:textColor="#8090A4"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/empty_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="38dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今天没有课"
                android:textColor="#15253D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/empty_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="点左右切换日期，中间按钮回到今天"
                android:textColor="#5E718B"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
