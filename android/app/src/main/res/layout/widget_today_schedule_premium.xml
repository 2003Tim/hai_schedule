<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_glass"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top|center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/header_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="3月8日"
                android:textColor="#15253D"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/header_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:text="星期六 · 今天 · 第2周 · 2节"
                android:textColor="#5E718B"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/widget_nav_btn_bg_light"
            android:gravity="center"
            android:text="‹"
            android:textColor="#24415F"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_today"
            android:layout_width="36dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_nav_btn_active_bg_light"
            android:gravity="center"
            android:text="今"
            android:textColor="#2158C7"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_nav_btn_bg_light"
            android:gravity="center"
            android:text="›"
            android:textColor="#24415F"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/top_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#D7E0EA" />

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/course_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/course_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/widget_course_glass"
                android:gravity="center_vertical"
                android:minHeight="62dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/course_indicator_1"
                    android:layout_width="3dp"
                    android:layout_height="34dp"
                    android:background="#C9D9F6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/course_title_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="机器学习"
                        android:textColor="#15253D"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/course_meta_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="1-T303 · 第7/20周 · 1-16周"
                        android:textColor="#6A7C96"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="end"
                    android:minWidth="70dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/course_status_row_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/course_reminder_badge_1"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/widget_badge_glass"
                            android:gravity="center"
                            android:text="提"
                            android:textColor="#2158C7"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/course_silence_badge_1"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/widget_badge_glass"
                            android:gravity="center"
                            android:text="静"
                            android:textColor="#006D77"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/course_status_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="end"
                        android:maxLines="1"
                        android:text="30分钟后"
                        android:textColor="#2158C7"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="10dp">

                    <ImageView
                        android:id="@+id/course_ring_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/course_week_value_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2/20"
                            android:textColor="#2158C7"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/course_week_label_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="周"
                            android:textColor="#8090A4"
                            android:textSize="8sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/course_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_course_glass"
                android:gravity="center_vertical"
                android:minHeight="62dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/course_indicator_2"
                    android:layout_width="3dp"
                    android:layout_height="34dp"
                    android:background="#D6CFF7" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/course_title_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="数据挖掘"
                        android:textColor="#15253D"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/course_meta_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="2-306 · 第7/20周 · 1-16周"
                        android:textColor="#6A7C96"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="end"
                    android:minWidth="70dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/course_status_row_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/course_reminder_badge_2"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/widget_badge_glass"
                            android:gravity="center"
                            android:text="提"
                            android:textColor="#2158C7"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/course_silence_badge_2"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/widget_badge_glass"
                            android:gravity="center"
                            android:text="静"
                            android:textColor="#006D77"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/course_status_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="end"
                        android:maxLines="1"
                        android:text="剩18分钟"
                        android:textColor="#006D77"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="10dp">

                    <ImageView
                        android:id="@+id/course_ring_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/course_week_value_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2/20"
                            android:textColor="#2158C7"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/course_week_label_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="周"
                            android:textColor="#8090A4"
                            android:textSize="8sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/more_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="还有 1 节课程未显示"
                android:textColor="#8090A4"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/empty_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/empty_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="☀"
                android:textColor="#C46A49"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="今天无课"
                android:textColor="#15253D"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/empty_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxLines="1"
                android:text="尽享时光"
                android:textColor="#5E718B"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
